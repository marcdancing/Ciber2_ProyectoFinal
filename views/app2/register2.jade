extends ../layout

block content
  .chat-page
    .chat-container.small
      .chat-header
        h1.chat-title= title
        a.chat-link(href='/auth2/login') Ir al login

      .chat-body
        form.chat-form(action='/auth2/register' method='POST')
          input.chat-input(type='text' name='username' placeholder='Nombre de usuario' required)
          input.chat-input(type='email' name='email' placeholder='Correo electrónico' required)
          input.chat-input(type='password' name='password' placeholder='Contraseña' required)
          button.chat-button(type='submit') Registrarse

        .auth-footer
          p ¿Ya tienes cuenta?
          a.chat-link.secondary(href='/auth2/login') Inicia sesión